<section class="intrinsics-restocker-config-body">
    <div class="form-group">
        <label for="restocker-theme">{{localize "INTRINSICS_RESTOCKER.Config.theme"}}</label>
        <div class="form-fields">
            <select id="restocker-theme" name="theme">
                <option value="" {{#unless currentTheme}}selected{{/unless}}>
                    {{localize "INTRINSICS_RESTOCKER.Config.selectTheme"}}
                </option>
                {{#each themes}}
                    <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>
                        {{this.label}}{{#if this.isEquipmentVendor}} ★{{/if}}
                    </option>
                {{/each}}
            </select>
        </div>
        <p class="hint">
            {{localize "INTRINSICS_RESTOCKER.Config.themeHint"}}
            <br>
            <small>★ {{localize "INTRINSICS_RESTOCKER.Config.equipmentVendor"}}</small>
        </p>
    </div>

    <div class="form-group">
        <label for="restocker-budget">{{localize "INTRINSICS_RESTOCKER.Config.budget"}}</label>
        <div class="form-fields">
            <input type="number" id="restocker-budget" name="budget"
                   value="{{currentBudget}}" min="1" step="1" required>
        </div>
        <p class="hint">{{localize "INTRINSICS_RESTOCKER.Config.budgetHint"}}</p>
    </div>

    <div class="form-group">
        <label for="restocker-compendium">{{localize "INTRINSICS_RESTOCKER.Config.compendium"}}</label>
        <div class="form-fields">
            <select id="restocker-compendium" name="compendium">
                <option value="" {{#unless currentCompendium}}selected{{/unless}}>
                    {{localize "INTRINSICS_RESTOCKER.Config.noCompendium"}}
                </option>
                {{#each compendiums}}
                    <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>
                        {{this.label}}
                    </option>
                {{/each}}
            </select>
        </div>
        <p class="hint">{{localize "INTRINSICS_RESTOCKER.Config.compendiumHint"}}</p>
    </div>

    <div class="form-group">
        <label for="restocker-max-level">{{localize "INTRINSICS_RESTOCKER.Config.maxLevel"}}</label>
        <div class="form-fields">
            <input type="number" id="restocker-max-level" name="maxLevel"
                   value="{{currentMaxLevel}}" min="0" step="1" placeholder="—">
        </div>
        <p class="hint">{{localize "INTRINSICS_RESTOCKER.Config.maxLevelHint"}}</p>
    </div>

    <div class="form-group">
        <label for="restocker-max-rarity">{{localize "INTRINSICS_RESTOCKER.Config.maxRarity"}}</label>
        <div class="form-fields">
            <select id="restocker-max-rarity" name="maxRarity">
                {{#each rarities}}
                    <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                {{/each}}
            </select>
        </div>
        <p class="hint">{{localize "INTRINSICS_RESTOCKER.Config.maxRarityHint"}}</p>
    </div>
</section>
